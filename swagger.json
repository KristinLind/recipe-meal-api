{
  "swagger": "2.0",
  "info": {
    "title": "Recipe API",
    "description": "API documentation for recipes and meal plans",
    "version": "1.0.0"
  },
  "host": "cse341-node-r9gw.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/recipes/": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Get all recipes",
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Recipes"],
        "summary": "Create a new recipe",
        "consumes": ["application/json"],
        "parameters": [{
          "name": "body",
          "in": "body",
          "required": true,
          "schema": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "example": "Chicken Alfredo" },
              "ingredients": { "type": "array", "items": { "type": "string" }, "example": ["chicken", "pasta"] },
              "instructions": { "type": "string", "example": "Cook it" },
              "cookTime": { "type": "number", "example": 30 },
              "difficulty": { "type": "string", "example": "Medium" },
              "servings": { "type": "number", "example": 4 },
              "category": { "type": "string", "example": "Dinner" }
            }
          }
        }],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipes/{id}": {
      "get": {
        "tags": ["Recipes"],
        "summary": "Get a single recipe by ID",
        "parameters": [{ "name": "id", "in": "path", "required": true, "type": "string" }],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" }
        }
      },
      "put": {
        "tags": ["Recipes"],
        "summary": "Update a recipe",
        "consumes": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "example": "Updated Recipe" },
                "ingredients": { "type": "array", "items": { "type": "string" }, "example": ["new ingredient"] },
                "instructions": { "type": "string", "example": "Updated instructions" },
                "cookTime": { "type": "number", "example": 45 },
                "difficulty": { "type": "string", "example": "Easy" },
                "servings": { "type": "number", "example": 2 },
                "category": { "type": "string", "example": "Lunch" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "delete": {
        "tags": ["Recipes"],
        "summary": "Delete a recipe",
        "parameters": [{ "name": "id", "in": "path", "required": true, "type": "string" }],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      }
    },
    "/mealplans/": {
      "get": {
        "tags": ["MealPlans"],
        "summary": "Get all meal plans",
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["MealPlans"],
        "summary": "Create a meal plan",
        "parameters": [{
          "name": "body",
          "in": "body",
          "required": true,
          "schema": {
            "type": "object",
            "properties": {
              "day": { "type": "string", "example": "Monday" },
              "mealType": { "type": "string", "example": "Dinner" },
              "recipeId": { "type": "string", "example": "123abc" },
              "notes": { "type": "string", "example": "Family favorite" }
            }
          }
        }],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/mealplans/{id}": {
      "get": {
        "tags": ["MealPlans"],
        "summary": "Get a single meal plan by ID",
        "parameters": [{ "name": "id", "in": "path", "required": true, "type": "string" }],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" }
        }
      },
      "put": {
        "tags": ["MealPlans"],
        "summary": "Update a meal plan",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "day": { "type": "string", "example": "Tuesday" },
                "mealType": { "type": "string", "example": "Lunch" },
                "recipeId": { "type": "string", "example": "123abc" },
                "notes": { "type": "string", "example": "Updated note" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "delete": {
        "tags": ["MealPlans"],
        "summary": "Delete a meal plan",
        "parameters": [{ "name": "id", "in": "path", "required": true, "type": "string" }],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      }
    }
  }
}